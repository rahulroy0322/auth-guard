{
	"extends": "ts-config/nextjs",
	"compilerOptions": {
		"skipLibCheck": true,
		"incremental": true,

		"jsx": "react-jsx",

		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"**/*.mts"
	],
	"exclude": ["node_modules"]
}
