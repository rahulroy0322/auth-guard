{
	"extends": "ts-config/nextjs",
	"compilerOptions": {
		"tsBuildInfoFile": "node_modules/.tsbuildinfo",
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts",
		"**/*.mts"
	],
	"exclude": ["node_modules", "drizzle.config.ts"]
}
