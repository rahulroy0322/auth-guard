{
	"name": "@auth-guard/mail",
	"version": "1.0.0",
	"description": "Mail utilities for Auth Guard with Nodemailer and EJS email templates.",
	"main": "dist/main.js",
	"types": "dist/main.d.ts",
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/main.d.ts",
			"default": "./dist/main.js"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"default": "./dist/*.js"
		}
	},
	"scripts": {
		"build": "tsc -b",
		"check": "biome check",
		"check:fix": "biome check --fix",
		"prepublishOnly": "npm run build"
	},
	"author": {
		"email": "rahulroyapd80@gmail.com",
		"name": "Rahul Roy",
		"url": "https://github.com/rahulroy0322"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rahulroy0322/auth-guard.git",
		"directory": "packages/mail"
	},
	"license": "MIT",
	"bugs": "https://github.com/rahulroy0322/auth-guard/issues",
	"homepage": "https://github.com/rahulroy0322/auth-guard#readme",
	"keywords": [
		"nodemailer",
		"email",
		"email-js",
		"node-email"
	],
	"dependencies": {
		"ejs": "^5.0.1",
		"nodemailer": "^8.0.4"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/ejs": "^3.1.5",
		"@types/nodemailer": "^7.0.11",
		"biome-config": "workspace:^",
		"ts-config": "workspace:^"
	}
}
