{
	"name": "@auth-guard/nextjs",
	"version": "0.1.1",
	"description": "Next.js client library for Auth Guard with provider state, auth UI, account panels, and DIY auth forms.",
	"sideEffects": false,
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist"
	],
	"main": "./dist/main.js",
	"module": "./dist/main.mjs",
	"types": "./dist/main.d.ts",
	"exports": {
		".": {
			"types": "./dist/main.d.ts",
			"import": "./dist/main.mjs",
			"require": "./dist/main.js"
		},
		"./diy": {
			"types": "./dist/diy.d.ts",
			"import": "./dist/diy.mjs",
			"require": "./dist/diy.js"
		},
		"./server": {
			"types": "./dist/server/main.d.ts",
			"import": "./dist/server/main.mjs",
			"require": "./dist/server/main.js"
		},
		"./styles.css": "./dist/main.css"
	},
	"scripts": {
		"build": "tsc -b && tsup",
		"check": "biome check",
		"check:fix": "biome check --fix",
		"dev": "tsup --watch",
		"prepublishOnly": "npm run build"
	},
	"author": {
		"name": "Rahul Roy",
		"email": "rahulroyapd80@gmail.com",
		"url": "https://github.com/rahulroy0322"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rahulroy0322/auth-guard.git",
		"directory": "packages/nextjs"
	},
	"license": "MIT",
	"bugs": "https://github.com/rahulroy0322/auth-guard/issues",
	"homepage": "https://github.com/rahulroy0322/auth-guard/tree/main/packages/nextjs#readme",
	"keywords": [
		"auth",
		"authentication",
		"next.js",
		"next.js-auth",
		"auth-provider",
		"oauth",
		"login",
		"register",
		"account"
	],
	"engines": {
		"node": ">=18"
	},
	"devDependencies": {
		"@auth-guard/backend": "workspace:^",
		"@auth-guard/react": "workspace:^",
		"@biomejs/biome": "2.4.8",
		"biome-config": "workspace:^",
		"schema": "workspace:^",
		"ts-config": "workspace:^",
		"tsup": "^8.5.1"
	},
	"peerDependencies": {
		"@auth-guard/backend": "^0",
		"@auth-guard/react": "^0",
		"next": "^15 || ^16",
		"react": "^18 || ^19",
		"react-dom": "^18 || ^19",
		"bcrypt": "^6",
		"jsonwebtoken": "^9",
		"zod": "^4",
		"nanoid": "^5"
	},
	"optionalDependencies": {
		"use-sync-external-store": "^1"
	}
}
