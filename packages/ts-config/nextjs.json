{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./react.json",
	"compilerOptions": {
		"useDefineForClassFields": true,
		"target": "esnext",
		"module": "esnext",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx",
		"plugins": [
			{
				"name": "next"
			}
		]
	}
}
