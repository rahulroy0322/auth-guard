{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./base.json",
	"compilerOptions": {
		"useDefineForClassFields": true,
		"target": "esnext",
		"module": "esnext",

		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"types": ["vite/client"],

		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx"
	}
}
